{
  "name": "kingmenu-food-planner",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "homepage": "https://kamel73-web.github.io/KingMenu",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "preview": "vite preview",
    "clean": "rm -rf dist node_modules/.vite",
    "clean:build": "npm run clean && npm run build",
    "deploy": "npm run clean:build && npx gh-pages -d dist --dotfiles --nojekyll --add --remote origin --message \"Deploy: $(date '+%Y-%m-%d %H:%M:%S')\"",
    "deploy:force": "rm -rf dist node_modules/.vite && npm run build && (cd dist && git init && git checkout -b gh-pages && git add -A && git commit -m \"Deploy: $(date '+%Y-%m-%d %H:%M:%S')\" && git remote add origin https://github.com/kamel73-web/KingMenu.git && git push origin gh-pages --force)"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/cli": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@supabase/supabase-js": "^2.50.2",
    "framer-motion": "^11.11.9",
    "html2canvas": "^1.4.1",
    "i18next": "^23.15.1",
    "i18next-browser-languagedetector": "^8.0.0",
    "jspdf": "^2.5.1",
    "lucide-react": "^0.453.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "react-i18next": "^15.0.2",
    "react-modal": "^3.16.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.11.1",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.9",
    "@tailwindcss/typography": "^0.5.15",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/react-modal": "^3.16.3",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.11.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.12",
    "gh-pages": "^6.1.1",
    "globals": "^15.11.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
